// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model EmploymentContract {
  id              String   @id @default(uuid())
  contractNumber  String   @unique
  effectiveFrom   String
  
  // Personal Details
  fullName        String
  dateOfBirth     String
  age             Int
  nationality     String
  cdcNumber       String
  address         String   @db.Text
  
  // Position Details
  crewCode        String
  position        String
  placeOfBirth    String
  ppNumber        String
  
  // Vessel Details
  vesselName      String
  imoNumber       String
  registeredOwner String
  certificateOfRegistry String
  portOfRegistry  String
  shipownerAddress String   @db.Text
  managerAddress  String   @db.Text
  vesselOwnerAddress String @db.Text
  
  // Contract Terms
  contractTerm    String
  placeOfEngagement String
  contractStartDate String
  contractExpiryDate String
  
  // Wage Breakdown
  basicWages      Decimal  @db.Decimal(10, 2)
  employerSpecialAllowance Decimal @db.Decimal(10, 2)
  fixedOvertime   Decimal  @db.Decimal(10, 2)
  leavePay        Decimal  @db.Decimal(10, 2)
  subsistenceAllowance Decimal @db.Decimal(10, 2)
  specialAllowance Decimal @db.Decimal(10, 2)
  uniformAllowance Decimal @db.Decimal(10, 2)
  totalMonthlySalary Decimal @db.Decimal(10, 2)
  netMonthlySalary Decimal @db.Decimal(10, 2)
  
  // Signature & Authentication
  signature       String?  @db.Text
  email           String?
  place           String?
  
  // Relations
  otherEarnings   OtherEarning[]
  deductions      Deduction[]
  salaryRevisions SalaryRevision[]
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([contractNumber])
  @@index([vesselName])
}

model OtherEarning {
  id          String   @id @default(uuid())
  description String
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  date        String
  
  contractId  String
  contract    EmploymentContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@index([contractId])
}

model Deduction {
  id          String   @id @default(uuid())
  description String
  amount      Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  date        String
  
  contractId  String
  contract    EmploymentContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@index([contractId])
}

model SalaryRevision {
  id            String   @id @default(uuid())
  sno           Int
  effectiveFrom String
  salary        Decimal  @db.Decimal(10, 2)
  remarks       String   @db.Text
  
  contractId    String
  contract      EmploymentContract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  
  @@index([contractId])
}

// Replicated from portage_bill_v1

model companies {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String               @unique @db.VarChar(255)
  registration_number String?              @db.VarChar(100)
  country             String               @db.VarChar(100)
  flag                String               @db.VarChar(100)
  address             String?
  contact_email       String?              @db.VarChar(255)
  contact_phone       String?              @db.VarChar(50)
  is_active           Boolean?             @default(true)
  created_at          DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?            @default(now()) @db.Timestamptz(6)
  
  seafarers           seafarers[]
  vessels             vessels[]

  @@index([name], map: "idx_companies_name")
}

model vessels {
  id                                   String                                 @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name                                 String                                 @db.VarChar(255)
  imo_number                           String                                 @unique @db.VarChar(20)
  call_sign                            String?                                @db.VarChar(20)
  flag                                 String                                 @db.VarChar(100)
  company_id                           String?                                @db.Uuid
  vessel_type                          String?                                @db.VarChar(100)
  gross_tonnage                        Int?
  is_active                            Boolean?                               @default(true)
  created_at                           DateTime?                              @default(now()) @db.Timestamptz(6)
  updated_at                           DateTime?                              @default(now()) @db.Timestamptz(6)
  financial_year_start_month           Int?                                   @default(1) @db.SmallInt
  
  contracts                            contracts[]
  seafarers                            seafarers[]
  companies                            companies?                             @relation(fields: [company_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  seafarer_contract_version_schedule   seafarer_contract_version_schedule[]
  seafarer_contract_version_overrides  seafarer_contract_version_overrides[]

  @@index([company_id], map: "idx_vessels_company_id")
  @@index([imo_number], map: "idx_vessels_imo_number")
  @@index([name], map: "idx_vessels_name")
}

model seafarers {
  id                                   String                                 @id @default(uuid()) @db.Uuid
  name                                 String                                 @db.VarChar(255)
  rank                                 String                                 @db.VarChar(100)
  nationality                          String                                 @db.VarChar(100)
  vessel_id                            String?                                @db.Uuid
  company_id                           String?                                @db.Uuid
  is_active                            Boolean?                               @default(true)
  created_at                           DateTime?                              @default(now()) @db.Timestamptz(6)
  updated_at                           DateTime?                              @default(now()) @db.Timestamptz(6)
  sign_on_date                         DateTime?                              @db.Date
  sign_off_date                        DateTime?                              @db.Date
  contract_start_date                  DateTime?                              @db.Date
  contract_end_date                    DateTime?                              @db.Date
  crew_code                            String?                                @db.VarChar(256)
  sea_experience_id                    BigInt?
  contract_id                          BigInt?
  seafarer_id                          BigInt?
  
  contracts                            contracts[]
  companies                            companies?                             @relation(fields: [company_id], references: [id])
  vessels                              vessels?                               @relation(fields: [vessel_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  seafarer_contract_version_schedule   seafarer_contract_version_schedule[]
  seafarer_contract_version_overrides  seafarer_contract_version_overrides[]

  @@index([company_id], map: "idx_seafarers_company_id")
  @@index([contract_end_date], map: "idx_seafarers_contract_end")
  @@index([contract_start_date], map: "idx_seafarers_contract_start")
  @@index([name], map: "idx_seafarers_name")
  @@index([sign_off_date], map: "idx_seafarers_sign_off")
  @@index([sign_on_date], map: "idx_seafarers_sign_on")
  @@index([vessel_id, is_active], map: "idx_seafarers_vessel_active")
  @@index([vessel_id], map: "idx_seafarers_vessel_id")
}

model contracts {
  id                                   String                                 @id @default(uuid()) @db.Uuid
  created_at                           DateTime?                              @default(now()) @db.Timestamptz(6)
  updated_at                           DateTime?                              @default(now()) @db.Timestamptz(6)
  COMPANY_ID                           String?                                @db.Uuid
  DEPARTMENT_ID                        String?                                @db.Uuid
  contract_id                          BigInt?
  uuid                                 String?                                @unique @db.VarChar(256)
  position_id                          BigInt?
  start_date                           DateTime?                              @db.Timestamptz(6)
  end_date                             DateTime?                              @db.Timestamptz(6)
  is_active                            Boolean?                               @default(true)
  status                               String?                                @db.VarChar(256)
  is_digitally_signed                  Boolean?                               @default(false)
  agreement_type                       String?                                @db.VarChar(256)
  agreement_no                         String?                                @db.VarChar(256)
  external_agreement_id                String?                                @db.VarChar(256)
  contract_terms                       String?
  notes                                String?
  place_of_engagement                  String?                                @db.VarChar(256)
  cba                                  String?                                @db.VarChar(256)
  created_by_name                      String?                                @db.VarChar(256)
  updated_by_name                      String?                                @db.VarChar(256)
  task_id                              String?                                @db.VarChar(256)
  seafarer_info                        Json?
  vessel_info                          Json?
  metadata                             Json?
  wages_info                           Json?
  revised_salary_info                  Json?
  seafarer_id                          String?                                @db.Uuid
  vessel_id                            String?                                @db.Uuid
  source                               String?                                @default("SAC") @db.VarChar(256)
  seafarer_detail_id                   String?                                @db.Uuid
  vessel_detail_id                     String?                                @db.Uuid
  company_detail_id                    String?                                @db.Uuid
  cba_detail_id                        String?                                @db.Uuid
  source_created_at                    DateTime?                              @db.Timestamptz(6)
  source_updated_at                    DateTime?                              @db.Timestamptz(6)
  fivetran_synced_at                   DateTime?                              @db.Timestamptz(6)
  
  seafarers                            seafarers?                             @relation(fields: [seafarer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_contracts_seafarer_id")
  vessels                              vessels?                               @relation(fields: [vessel_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_contracts_vessel_id")
  seafarer_contract_version_overrides  seafarer_contract_version_overrides[]
  seafarer_contract_version_schedule   seafarer_contract_version_schedule[]

  @@unique([contract_id, agreement_no], map: "unique_contract_id_agreement")
  @@index([contract_id], map: "idx_contracts_contract_id")
  @@index([created_at], map: "idx_contracts_created_at")
  @@index([end_date], map: "idx_contracts_end_date")
  @@index([metadata], map: "idx_contracts_metadata", type: Gin)
  @@index([position_id], map: "idx_contracts_position_id")
  @@index([revised_salary_info], map: "idx_contracts_revised_salary_info", type: Gin)
  @@index([seafarer_id], map: "idx_contracts_seafarer_id")
  @@index([seafarer_info], map: "idx_contracts_seafarer_info", type: Gin)
  @@index([start_date], map: "idx_contracts_start_date")
  @@index([updated_at], map: "idx_contracts_updated_at")
  @@index([uuid], map: "idx_contracts_uuid")
  @@index([vessel_id], map: "idx_contracts_vessel_id")
  @@index([vessel_info], map: "idx_contracts_vessel_info", type: Gin)
  @@index([vessel_id, seafarer_id, start_date, end_date], map: "idx_contracts_vessel_seafarer_dates")
  @@index([wages_info], map: "idx_contracts_wages_info", type: Gin)
  @@index([source_updated_at], map: "idx_contracts_source_updated_at")
}

model seafarer_contract_version_schedule {
  id                       String    @id @default(uuid()) @db.Uuid
  seafarer_id              String    @db.Uuid
  vessel_id                String    @db.Uuid
  effective_from           DateTime  @db.Date
  selected_contract_row_id String    @db.Uuid
  contract_id              BigInt?
  agreement_no             String?
  created_at               DateTime? @default(now()) @db.Timestamptz(6)
  updated_at               DateTime? @default(now()) @db.Timestamptz(6)
  created_by               String?   @db.Uuid
  updated_by               String?   @db.Uuid
  contracts                contracts @relation(fields: [selected_contract_row_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sc_version_schedule_contract_row_id")
  seafarers                seafarers @relation(fields: [seafarer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sc_version_schedule_seafarer_id")
  vessels                  vessels   @relation(fields: [vessel_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sc_version_schedule_vessel_id")

  @@unique([seafarer_id, vessel_id, effective_from], map: "idx_seafarer_version_schedule_unique")
}

model seafarer_contract_version_overrides {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seafarer_id     String    @db.Uuid
  vessel_id       String    @db.Uuid
  contract_row_id String    @db.Uuid
  is_excluded     Boolean   @default(false)
  force_include   Boolean   @default(false)
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)
  created_by      String?   @db.Uuid
  updated_by      String?   @db.Uuid
  contracts       contracts @relation(fields: [contract_row_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sc_version_overrides_contract_row_id")
  seafarers       seafarers @relation(fields: [seafarer_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sc_version_overrides_seafarer_id")
  vessels         vessels   @relation(fields: [vessel_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_sc_version_overrides_vessel_id")

  @@unique([seafarer_id, vessel_id, contract_row_id], map: "unique_seafarer_vessel_contract_override")
  @@index([seafarer_id, vessel_id], map: "idx_sc_version_overrides_seafarer_vessel")
  @@index([contract_row_id], map: "idx_sc_version_overrides_contract_row")
}
